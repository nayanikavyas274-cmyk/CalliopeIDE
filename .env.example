# Server Configuration
PORT=5000
FLASK_ENV=development
APP_ENV=development

# Frontend Runtime
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Database
DATABASE_URL=sqlite:///data/calliope.db

# Security Keys (REQUIRED - Generate using the command below)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# JWT Token Expiration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Gemini API (for AI agent)
GEMINI_API_KEY=your-gemini-api-key-here

# Backend URL (used to build OAuth redirect URIs)
BACKEND_URL=http://localhost:5000

# GitHub OAuth
# 1. Go to https://github.com/settings/developers → "New OAuth App"
# 2. Homepage URL:           http://localhost:3000
# 3. Authorization callback: http://localhost:5000/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorised redirect URI: http://localhost:5000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=